# ==========================================
# Database Configuration (PostgreSQL)
# ==========================================
# Ganti dengan kredensial database lokal/production kamu
DB_USER="postgres"
DB_PASS="password_db_kamu"
DB_HOST="localhost"
DB_PORT="5432"
DB_NAME="porto_db"


# ==========================================
# Application URL
# ==========================================
# URL utama aplikasi (digunakan di sisi client)
PORT=3000
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ==========================================
# Authentication (Better Auth)
# ==========================================
# Generate secret key yang kuat (misal: openssl rand -base64 32)
BETTER_AUTH_SECRET="your-super-secret-key-min-32-chars"
# URL utama untuk proses autentikasi
BETTER_AUTH_URL="http://localhost:3000"

# ==========================================
# File Storage (Cloudflare R2 / S3 Compatible)
# ==========================================
# Konfigurasi bucket untuk upload file (CV, gambar, dll.)
R2_ACCOUNT_ID="your_cloudflare_account_id"
R2_ACCESS_KEY_ID="your_r2_access_key_id"
R2_SECRET_ACCESS_KEY="your_r2_secret_access_key"
R2_BUCKET_NAME="your_bucket_name"
# URL publik atau custom domain bucket kamu untuk menampilkan file
R2_PUBLIC_URL="pub-xxxxxx.r2.dev"

# ==========================================
# Redis (Caching & Rate Limiting)
# ==========================================
REDIS_HOST="localhost"
REDIS_PORT="6379"
REDIS_PASS=""

# ==========================================
# SMTP Configuration (Contact Form)
# ==========================================
SMTP_HOST="your-smtp-host.com"
SMTP_PORT="587"
SMTP_USER="your-email@domain.com"
SMTP_PASS="your-smtp-password"
SMTP_FROM="\"Contact Form\" <your-email@domain.com>"
ADMIN_EMAIL="admin@domain.com"
